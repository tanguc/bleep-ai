{
    // ── formatting ───────────────────────────────────────────────────
    "[rust]": {
        "editor.defaultFormatter": "rust-lang.rust-analyzer",
        "editor.formatOnSave": true
    },
    "rust-analyzer.rustfmt.rangeFormatting.enable": true,

    // ── on-save: cargo check, NOT clippy + pedantic ──────────────────
    // pedantic clippy on every save is 3-5x slower than `cargo check`.
    // run clippy manually via `task lint` when you actually want it.
    // allTargets: true — without this, RA analyzes src/ files in the
    // context of whichever [[bin]] it picks first (tui, build-rules…),
    // causing spurious dead_code warnings for symbols only used by the
    // main bleep-gateway binary.
    "rust-analyzer.check.command": "check",
    "rust-analyzer.check.allTargets": true,

    // ── target dir: separate from terminal builds ───────────────────
    // without this, `cargo build` (or `task run`) and rust-analyzer
    // fight for the same target/, invalidating each other constantly.
    // RA gets its own target/rust-analyzer-check dir.
    "rust-analyzer.cargo.targetDir": true,

    // ── proc macros: enabled but with reasonable scope ──────────────
    "rust-analyzer.procMacro.enable": true,
    "rust-analyzer.cargo.buildScripts.enable": true,

    // ── hover/inlay hints: keep but cap parameter inlay verbosity ───
    "rust-analyzer.inlayHints.parameterHints.enable": false,
    "rust-analyzer.inlayHints.closingBraceHints.enable": false,

    // ── linked projects: gateway + Tauri crate (separate Cargo.locks) ─
    "rust-analyzer.linkedProjects": [
        "Cargo.toml",
        "apps/menu-bar/src-tauri/Cargo.toml"
    ],

    // ── exclude noisy dirs from the file watcher ────────────────────
    "files.watcherExclude": {
        "**/target/**": true,
        "**/.task/**": true,
        "**/node_modules/**": true,
        "**/.git/objects/**": true
    }
}
