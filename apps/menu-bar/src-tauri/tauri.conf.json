{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Bleep",
  "version": "0.1.0",
  "identifier": "ai.bleep.menubar",
  "build": {
    "frontendDist": "../ui",
    "devUrl": null
  },
  "app": {
    "windows": [],
    "withGlobalTauri": true,
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; connect-src 'self' http://127.0.0.1:* ws://127.0.0.1:* ipc: https://ipc.localhost"
    }
  },
  "bundle": {
    "active": true,
    "category": "DeveloperTool",
    "targets": ["app"],
    "macOS": {
      "minimumSystemVersion": "11.0",
      "signingIdentity": null
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/icon.png"
    ]
  }
}
